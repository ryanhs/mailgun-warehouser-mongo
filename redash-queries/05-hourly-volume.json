{
    "collection": "events",
    "aggregate": [
        {
            "$match": {
                "@timestamp": {
                    "$gte": "ISODate(\"{{ dateRange.start }}T00:00:00Z\")",
                    "$lte": "ISODate(\"{{ dateRange.end }}T23:59:59Z\")"
                }
            }
        },
        {
            "$group": {
                "_id": {
                    "date": { "$dateToString": { "format": "%Y-%m-%d", "date": "$@timestamp" } },
                    "hour": { "$dateToString": { "format": "%H", "date": "$@timestamp" } }
                },
                "count": { "$sum": 1 }
            }
        },
        {
            "$project": {
                "_id": 0,
                "date": "$_id.date",
                "hour": "$_id.hour",
                "count": 1
            }
        },
        {
            "$sort": [{ "name": "date", "direction": 1 }, { "name": "hour", "direction": 1 }]
        }
    ]
}
